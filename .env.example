# AI Scrum Master Environment Variables

# Backend
API_KEY=demo-api-key
DATABASE_URL=sqlite:///./scrum_master.db
DEBUG=True
SECRET_KEY=your-secret-key-here

# AI Services (Optional - internal AI doesn't require external APIs)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
WHISPER_API_KEY=your_whisper_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# Frontend
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_VOICE_API_KEY=your_voice_api_key_here
REACT_APP_CHART_API_KEY=your_chart_api_key_here
